# OpenClaw Market Intel - Environment Variables
# Copy this file to .env and fill in your API keys

# Anthropic (Claude LLM)
ANTHROPIC_API_KEY=

# Finnhub (Sentiment + News)
FINNHUB_API_KEY=

# FRED (Macro/Fed data)
FRED_API_KEY=

# Alpaca (Broker)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_MODE=paper  # "paper" or "live"

# Telegram Bot
TELEGRAM_BOT_TOKEN=
ALLOWED_USER_IDS=  # Comma-separated Telegram user IDs

# Quiver Quantitative (Congressional trades)
QUIVER_API_KEY=

# SNS Notifications (AWS)
SNS_PHONE_NUMBER=  # +1XXXXXXXXXX format
SNS_TOPIC_ARN=     # Created by CloudFormation
